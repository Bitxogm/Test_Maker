#!/bin/sh

# =============================================================
#  .husky/pre-commit
#  Compatible con Linux, Mac y Windows (Git for Windows).
#  Adaptado para pnpm y ESLint v9 flat config.
# =============================================================

echo ""
echo "🔧 Ejecutando validaciones pre-commit..."
echo ""

# ── 1. DETECCIÓN DE SECRETOS ────────────────────────────────
node scripts/check-secrets.js

if [ $? -ne 0 ]; then
  exit 1
fi

# ── 2. ESLINT ───────────────────────────────────────────────
echo "🔍 Ejecutando ESLint en archivos modificados..."
echo ""

# El "|| true" evita que grep devuelva exit code 1 cuando no hay coincidencias,
# lo que mataría el script aunque no sea un error real.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "Archivos a validar:"
  echo "$STAGED_FILES"
  echo ""

  STAGED_FILES_CLEAN=$(echo "$STAGED_FILES" | tr '\\' '/')

  pnpm lint $STAGED_FILES_CLEAN

  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ ESLint encontró errores."
    echo ""
    echo "   → pnpm lint:fix          (intentar corregir automáticamente)"
    echo "   → git commit --no-verify  (saltar validaciones, no recomendado)"
    echo ""
    exit 1
  fi

  echo "✅ ESLint: Sin errores"
else
  echo "ℹ️  No hay archivos TS/JS para validar"
fi

# ── 3. PRETTIER (descomenta si quieres validar formato) ─────
# echo ""
# echo "💅 Comprobando formato con Prettier..."
# pnpm format:check
# if [ $? -ne 0 ]; then
#   echo "❌ Hay archivos sin formatear. Ejecuta: pnpm format"
#   exit 1
# fi
# echo "✅ Prettier: Formato correcto"

echo ""
echo "✅ Todas las validaciones pasaron. Realizando commit..."
echo ""
