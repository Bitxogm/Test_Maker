{
  "name": "testlab-ai",
  "version": "1.0.0",
  "private": true,
  "description": "TestLab AI - Generador y ejecutor de tests con IA",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "!(**/node_modules/**/*)*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(**/node_modules/**/*)*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.3",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.0.0",
    "typescript": "^5.3.3"
  }
}
